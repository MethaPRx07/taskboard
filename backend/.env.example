# ==========================================
# Calendar Task Management API - Environment
# ==========================================

# Server
HOST=127.0.0.1
PORT=3000

# Database
DATABASE_URL=postgres://postgres:password@localhost:5432/taskboard

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_ACCESS_EXPIRY_SECONDS=900       # 15 minutes
JWT_REFRESH_EXPIRY_SECONDS=604800   # 7 days

# Logging
RUST_LOG=info
